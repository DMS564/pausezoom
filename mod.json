{
    "geode": "4.2.0",
    "gd": {
        "win": "2.2081",
        "mac": "2.2081",
        "android": "2.2081"
    },
    "id": "pausezoom.pause-zoom",
    "name": "Pause Zoom",
    "version": "v1.0.0",
    "developer": "PauseZoom",
    "description": "Zoom in and out on the pause menu using your scroll wheel. Scroll up to zoom in, scroll down to zoom out.",
    "tags": ["interface", "enhancement", "utility"],
    "settings": {
        "zoom-speed": {
            "name": "Zoom Speed",
            "description": "How fast the zoom changes per scroll tick.",
            "type": "float",
            "default": 0.1,
            "min": 0.01,
            "max": 0.5
        },
        "max-zoom": {
            "name": "Max Zoom",
            "description": "Maximum zoom level.",
            "type": "float",
            "default": 5.0,
            "min": 1.5,
            "max": 20.0
        },
        "min-zoom": {
            "name": "Min Zoom",
            "description": "Minimum zoom level.",
            "type": "float",
            "default": 0.2,
            "min": 0.05,
            "max": 1.0
        },
        "smooth-zoom": {
            "name": "Smooth Zoom",
            "description": "Enable smooth animated zooming.",
            "type": "bool",
            "default": true
        },
        "reset-on-close": {
            "name": "Reset Zoom on Close",
            "description": "Reset zoom level when closing the pause menu.",
            "type": "bool",
            "default": true
        }
    }
}
